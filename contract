pragma solidity ^0.8.29;

import "https://raw.githubusercontent.com/OpenZeppelin/openzeppelin-contracts-upgradeable/v4.9.6/contracts/token/ERC721/extensions/ERC721URIStorageUpgradeable.sol";
import "https://raw.githubusercontent.com/OpenZeppelin/openzeppelin-contracts-upgradeable/v4.9.6/contracts/access/OwnableUpgradeable.sol";
import "https://raw.githubusercontent.com/OpenZeppelin/openzeppelin-contracts-upgradeable/v4.9.6/contracts/security/ReentrancyGuardUpgradeable.sol";
import "https://raw.githubusercontent.com/OpenZeppelin/openzeppelin-contracts-upgradeable/v4.9.6/contracts/proxy/utils/Initializable.sol";
import "https://raw.githubusercontent.com/OpenZeppelin/openzeppelin-contracts-upgradeable/v4.9.6/contracts/proxy/utils/UUPSUpgradeable.sol";
import "https://raw.githubusercontent.com/OpenZeppelin/openzeppelin-contracts-upgradeable/v4.9.6/contracts/token/common/ERC2981Upgradeable.sol";

contract ChainversNFT is
    Initializable,
    ERC721URIStorageUpgradeable,
    ERC2981Upgradeable,
    OwnableUpgradeable,
    ReentrancyGuardUpgradeable,
    UUPSUpgradeable
{
    uint256 public tokenIdCounter;
    uint256 public mintFee;

    struct Original {
        string privateURI;
        string publicURI;
        uint96 royalty;
        uint256 maxCopies;
        uint256 copiesMinted;
        bool exists;
    }

    struct Eco {
        uint96 o;
        uint96 t;
        uint96 c;
        bool custom;
    }

    mapping(uint256 => Original) public originals;
    mapping(uint256 => uint256) public copyToOriginal;
    mapping(uint256 => uint256) public originBalance;
    mapping(uint256 => uint256) public copyBalance;
    mapping(uint256 => Eco) public ecoModel;

    uint256 public treasuryBalance;
    bool public v3Initialized;

    error Fee();
    error Orig();
    error Max();
    error OwnerOnly();
    error Hundred();
    error Zero();
    error Copy();
    error SendFail();
    error BadTo();
    error LowBal();
    error Token();
    error NotTokenOwner();
    error InsufficientOrigin();
    error InsufficientCopy();
    error V3();

    event OriginalCreated(uint256 indexed id, address indexed owner, uint256 fee);
    event CopyMinted(uint256 indexed copyId, uint256 indexed originalId, address indexed owner, uint256 fee);
    event TokenWithdraw(uint256 indexed id, address indexed to, uint256 amount);
    event AdminTokenWithdraw(uint256 indexed id, address indexed to, uint256 amount);
    event TreasuryWithdraw(address indexed to, uint256 amount);
    event BackendCredit(uint256 indexed id, uint256 amount, string kind);

    constructor() {
        _disableInitializers();
    }

    function initialize() public initializer {
        __ERC721_init("CHAINVERS", "CHVS");
        __ERC721URIStorage_init();
        __Ownable_init();
        __ReentrancyGuard_init();
        __ERC2981_init();
        __UUPSUpgradeable_init();

        tokenIdCounter = 1;
        mintFee = 0.001 ether;
    }

    function createOriginal(
        string memory _privateURI,
        string memory _publicURI,
        uint96 _royalty,
        uint256 _maxCopies
    ) external payable nonReentrant {
        if (msg.value < mintFee) revert Fee();

        treasuryBalance += msg.value;

        uint256 newId = tokenIdCounter++;
        _mint(msg.sender, newId);
        _setTokenURI(newId, _publicURI);
        _setTokenRoyalty(newId, msg.sender, _royalty);

        originals[newId] = Original({
            privateURI: _privateURI,
            publicURI: _publicURI,
            royalty: _royalty,
            maxCopies: _maxCopies,
            copiesMinted: 0,
            exists: true
        });

        emit OriginalCreated(newId, msg.sender, msg.value);
    }

    function mintCopy(uint256 originalId) external payable nonReentrant {
        Original storage o = originals[originalId];

        if (!o.exists) revert Orig();
        if (o.copiesMinted >= o.maxCopies) revert Max();
        if (msg.value < mintFee) revert Fee();

        uint256 newCopyId = tokenIdCounter++;
        _mint(msg.sender, newCopyId);
        _setTokenURI(newCopyId, o.privateURI);
        _setTokenRoyalty(newCopyId, ownerOf(originalId), o.royalty);

        unchecked {
            o.copiesMinted++;
        }

        copyToOriginal[newCopyId] = originalId;
        _distributeMintFee(originalId, msg.value, newCopyId);

        emit CopyMinted(newCopyId, originalId, msg.sender, msg.value);
    }

    function setMintFee(uint256 _fee) external onlyOwner {
        mintFee = _fee;
    }

    function setTokenURI(uint256 tokenId, string memory newURI) external {
        if (ownerOf(tokenId) != msg.sender) revert OwnerOnly();
        if (!originals[tokenId].exists) revert Orig();

        _setTokenURI(tokenId, newURI);
    }

    function setEconomicModel(
        uint256 id,
        uint96 o,
        uint96 t,
        uint96 c
    ) external {
        if (!originals[id].exists) revert Orig();
        if (ownerOf(id) != msg.sender) revert OwnerOnly();
        if (o + t + c != 100) revert Hundred();

        ecoModel[id] = Eco({
            o: o,
            t: t,
            c: c,
            custom: true
        });
    }

    function _distributeMintFee(uint256 oid, uint256 amt, uint256 cid) internal {
        Eco memory m = ecoModel[oid];

        uint256 os = m.custom ? (amt * m.o) / 100 : (amt * 80) / 100;
        uint256 ts = m.custom ? (amt * m.t) / 100 : (amt * 15) / 100;
        uint256 cs = m.custom ? (amt * m.c) / 100 : (amt * 5) / 100;

        originBalance[oid] += os;
        treasuryBalance += ts;
        copyBalance[cid] += cs;
    }

    function withdrawOrigin(uint256 id) external nonReentrant {
        if (!originals[id].exists) revert Orig();
        if (ownerOf(id) != msg.sender) revert OwnerOnly();

        uint256 a = originBalance[id];
        if (a == 0) revert Zero();

        originBalance[id] = 0;
        _sendValue(msg.sender, a);

        emit TokenWithdraw(id, msg.sender, a);
    }

    function withdrawCopy(uint256 id) external nonReentrant {
        if (copyToOriginal[id] == 0) revert Copy();
        if (ownerOf(id) != msg.sender) revert OwnerOnly();

        uint256 a = copyBalance[id];
        if (a == 0) revert Zero();

        copyBalance[id] = 0;
        _sendValue(msg.sender, a);

        emit TokenWithdraw(id, msg.sender, a);
    }

    function withdrawTreasury() external onlyOwner nonReentrant {
        uint256 a = treasuryBalance;
        if (a == 0) revert Zero();

        treasuryBalance = 0;
        _sendValue(msg.sender, a);

        emit TreasuryWithdraw(msg.sender, a);
    }

    function backendCreditOrigin(uint256 id, uint256 amt) external onlyOwner {
        if (!originals[id].exists) revert Orig();
        if (amt == 0) revert Zero();

        originBalance[id] += amt;

        emit BackendCredit(id, amt, "origin");
    }

    function backendCreditCopy(uint256 id, uint256 amt) external onlyOwner {
        if (!_exists(id)) revert Token();
        if (copyToOriginal[id] == 0) revert Copy();
        if (amt == 0) revert Zero();

        copyBalance[id] += amt;

        emit BackendCredit(id, amt, "copy");
    }

    function backendCreditTreasury(uint256 amt) external onlyOwner {
        if (amt == 0) revert Zero();

        treasuryBalance += amt;

        emit BackendCredit(0, amt, "treasury");
    }

    function backendWithdrawToken(
        uint256 id,
        address to,
        uint256 amount
    ) external onlyOwner nonReentrant {
        if (to == address(0)) revert BadTo();
        if (amount == 0) revert Zero();
        if (!_exists(id)) revert Token();
        if (ownerOf(id) != to) revert NotTokenOwner();
        if (address(this).balance < amount) revert LowBal();

        if (originals[id].exists) {
            uint256 bal = originBalance[id];
            if (bal < amount) revert InsufficientOrigin();
            originBalance[id] = bal - amount;
        } else {
            if (copyToOriginal[id] == 0) revert Copy();
            uint256 bal = copyBalance[id];
            if (bal < amount) revert InsufficientCopy();
            copyBalance[id] = bal - amount;
        }

        _sendValue(to, amount);

        emit TokenWithdraw(id, to, amount);
    }

    function adminWithdrawToken(
        uint256 id,
        address to,
        uint256 amount
    ) external onlyOwner nonReentrant {
        if (to == address(0)) revert BadTo();
        if (amount == 0) revert Zero();
        if (!_exists(id)) revert Token();
        if (address(this).balance < amount) revert LowBal();

        if (originals[id].exists) {
            uint256 bal = originBalance[id];
            if (bal < amount) revert InsufficientOrigin();
            originBalance[id] = bal - amount;
        } else {
            if (copyToOriginal[id] == 0) revert Copy();
            uint256 bal = copyBalance[id];
            if (bal < amount) revert InsufficientCopy();
            copyBalance[id] = bal - amount;
        }

        _sendValue(to, amount);

        emit AdminTokenWithdraw(id, to, amount);
    }

    function emergencyWithdraw(address to, uint256 amount)
        external
        onlyOwner
        nonReentrant
    {
        if (to == address(0)) revert BadTo();
        if (amount == 0) revert Zero();
        if (address(this).balance < amount) revert LowBal();

        _sendValue(to, amount);
    }

    function tokenAvailableForWithdraw(uint256 id) external view returns (uint256) {
        if (!_exists(id)) revert Token();

        if (originals[id].exists) {
            return originBalance[id];
        }

        if (copyToOriginal[id] != 0) {
            return copyBalance[id];
        }

        return 0;
    }

    function isOriginalToken(uint256 id) external view returns (bool) {
        return originals[id].exists;
    }

    function upgradeV3() external reinitializer(3) {
        if (v3Initialized) revert V3();

        v3Initialized = true;
    }

    function _authorizeUpgrade(address newImplementation)
        internal
        override
        onlyOwner
    {}

    function _sendValue(address to, uint256 amount) internal {
        (bool ok, ) = payable(to).call{value: amount}("");
        if (!ok) revert SendFail();
    }

    function supportsInterface(bytes4 interfaceId)
        public
        view
        override(ERC721URIStorageUpgradeable, ERC2981Upgradeable)
        returns (bool)
    {
        return super.supportsInterface(interfaceId);
    }

    receive() external payable {
        treasuryBalance += msg.value;
    }

    fallback() external payable {
        treasuryBalance += msg.value;
    }

    uint256[50] private __gap;
}
